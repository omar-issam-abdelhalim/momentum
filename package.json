{
  "name": "momentum",
  "description": "A calm, offline-first PWA for weekly/daily goals and habit tracking, with a custom Saturday–Friday planning week.",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "author": "Omar Issam",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omar-issam-abdelhalim/momentum.git"
  },
  "homepage": "https://github.com/omar-issam-abdelhalim/momentum#readme",
  "bugs": {
    "url": "https://github.com/omar-issam-abdelhalim/momentum/issues"
  },
  "keywords": [
    "pwa",
    "offline-first",
    "goals",
    "habit-tracker",
    "productivity",
    "react",
    "typescript",
    "vite",
    "dexie",
    "indexeddb"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
